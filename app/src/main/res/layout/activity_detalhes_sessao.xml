<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/txtTituloSessao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sessão 09/06/2026"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtInicio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Início: 14:31"/>

                <TextView
                    android:id="@+id/txtFim"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fim: 15:42"/>

                <TextView
                    android:id="@+id/txtDuracao"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Duração: 1h11m"/>

                <TextView
                    android:id="@+id/txtEstadoFinal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FORNO_ATIVO"
                    android:textStyle="bold"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Gráfico de Temperatura"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/chartSessao"
            android:layout_width="match_parent"
            android:layout_height="250dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Eventos"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerEventosSessao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</ScrollView>